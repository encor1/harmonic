{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spectrum",
  "version": "0.1.0",
  "identifier": "dev.local.spectrum",
  "build": {
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Spectrum",
        "width": 1180,
        "height": 820
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
      "icon": [
    "icons/icon.png",
    "icons/32x32.png",
    "icons/64x64.png",
    "icons/128x128.png",
    "icons/128x128@2x.png",
    "icons/icon.icns",
    "icons/icon.ico"
  ]
  }
}
